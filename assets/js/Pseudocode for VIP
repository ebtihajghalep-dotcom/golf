function التحقق_من_الإدخالات():
    // جلب القيم من الإدخالات
    الاسم_الكامل = قيمة_الحقل("fullName")
    رقم_الهاتف = قيمة_الحقل("phoneNumber")
    التاريخ_المطلوب = قيمة_الحقل("requiredDate")
    عدد_الأشخاص = قيمة_الحقل("numPeople")
    نوع_الباقة = قيمة_الحقل("packageType")
    المتطلبات_الخاصة = قيمة_الحقل("specialReq")
    مدة_الإقامة = قيمة_الحقل("stayDuration")
    الميزانية = قيمة_الحقل("budget")
    البريد_الإلكتروني = قيمة_الحقل("email")
    الخدمات_الإضافية = قيمة_الحقل("additionalServices")

    // التحقق من أن جميع الحقول ليست فارغة
    إذا (أي_حقل_فارغ(الاسم_الكامل, رقم_الهاتف, التاريخ_المطلوب, عدد_الأشخاص, 
        نوع_الباقة, المتطلبات_الخاصة, مدة_الإقامة, الميزانية, البريد_الإلكتروني, الخدمات_الإضافية)):
        عرض_رسالة("خطأ: يرجى ملء جميع الحقول المطلوبة.")
        إرجاع false // منع إرسال النموذج

    إرجاع true // السماح بإرسال النموذج إذا كانت جميع الحقول ممتلئة

